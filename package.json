{
  "name": "mtg-live-counters",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter @mtg/shared build && pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm --filter @mtg/shared typecheck && pnpm --filter web typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
